# ─────────────────────────────────────────────────────────────────────────────
# Testream Vitest Reporter — Environment Variables
#
# Copy this file to .env and fill in your values.
# In CI/CD, set these as secrets / environment variables in your pipeline.
# ─────────────────────────────────────────────────────────────────────────────

# Required — Your Testream API key.
# Get one at: https://testream.app → Dashboard → Projects → API Keys
TESTREAM_API_KEY=your_api_key_here

# The environment label that will appear in Testream.
# Useful for distinguishing local runs from CI runs (e.g. "local", "ci", "staging").
TESTREAM_TEST_ENVIRONMENT=local

# A human-readable name for the application under test.
# This shows up in the Testream dashboard alongside each test run.
TESTREAM_APP_NAME=vitest-jira-reporter-example

# The version of your application (semver recommended).
# Helps you track which build a test run belongs to.
TESTREAM_APP_VERSION=1.0.0

# The type of tests in this run.
# Common values: unit, integration, e2e, smoke
TESTREAM_TEST_TYPE=unit
